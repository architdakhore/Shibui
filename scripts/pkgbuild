# Maintainer: Your Name <your.email@example.com>
# Contributor: FlowWM Team

pkgname=flowwm
pkgver=0.1.0
pkgrel=1
pkgdesc="A high-performance Wayland compositor with dynamic, horizontal, vertical, and center tiling layouts"
arch=('x86_64' 'aarch64')
url="https://github.com/yourusername/flowwm"
license=('MIT')
depends=(
    'wayland'
    'wayland-protocols'
    'mesa'
    'libglvnd'
    'libinput'
    'libxkbcommon'
    'systemd'
    'libdrm'
    'pixman'
)
makedepends=(
    'rust'
    'cargo'
    'git'
    'cmake'
    'ninja'
)
optdepends=(
    'vulkan-headers: for Vulkan renderer support'
    'pipewire: for screen capture support'
)
provides=('wayland-compositor')
conflicts=()
replaces=()
backup=('etc/flowwm/config.toml')
options=('!emptydirs')

# Source can be git or tarball
source=("${pkgname}::git+https://github.com/yourusername/flowwm.git#tag=v${pkgver}")
# Or for release tarballs:
# source=("https://github.com/yourusername/flowwm/archive/v${pkgver}.tar.gz")

sha256sums=('SKIP')

pkgver() {
    cd "${pkgname}"
    git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
    cd "${pkgname}"
    
    # Update submodules if any
    git submodule update --init --recursive
}

build() {
    cd "${pkgname}"
    
    # Build with release profile
    cargo build --frozen --features '' --release
    
    # Build man pages if available
    # make -C docs man
}

check() {
    cd "${pkgname}"
    
    # Run tests
    cargo test --frozen --features ''
}

package() {
    cd "${pkgname}"
    
    # Install binary
    install -Dm755 -t "${pkgdir}/usr/bin/" target/release/flowwm
    
    # Install license
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    
    # Install documentation
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    install -Dm644 INSTALL.md "${pkgdir}/usr/share/doc/${pkgname}/INSTALL.md"
    install -Dm644 CONFIG.md "${pkgdir}/usr/share/doc/${pkgname}/CONFIG.md"
    
    # Install config file
    install -Dm644 config/flowwm.toml "${pkgdir}/etc/flowwm/config.toml"
    
    # Install systemd user service
    install -Dm644 systemd/flowwm.service "${pkgdir}/usr/lib/systemd/user/flowwm.service"
    
    # Install Wayland session file
    install -Dm644 "${srcdir}/${pkgname}/flowwm.desktop" \
        "${pkgdir}/usr/share/wayland-sessions/flowwm.desktop"
    
    # Install shell completions
    # install -Dm644 completions/flowwm.bash "${pkgdir}/usr/share/bash-completion/completions/flowwm"
    # install -Dm644 completions/flowwm.zsh "${pkgdir}/usr/share/zsh/site-functions/_flowwm"
    # install -Dm644 completions/flowwm.fish "${pkgdir}/usr/share/fish/vendor_completions.d/flowwm.fish"
}

# vim:set ts=8 sw=4 et:
